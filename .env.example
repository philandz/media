RUST_LOG=media=debug,tower_http=debug

MEDIA_APP_NAME=media
MEDIA_APP_VERSION=0.1.0
MEDIA_APP_ENV=local

DATABASE_URL=mysql://root:root@127.0.0.1:3306/philand
JWT_SECRET=local-dev-jwt-secret

GRPC_HOST=127.0.0.1
GRPC_PORT=50052

HTTP_HOST=127.0.0.1
HTTP_PORT=3002
SERVICE_NAME=media

S3_ENDPOINT=http://127.0.0.1:3900
S3_REGION=garage
S3_ACCESS_KEY=replace-me
S3_SECRET_KEY=replace-me
S3_BUCKET=philand-v2-media-dev
S3_FORCE_PATH_STYLE=true
# Internal endpoint for server-side operations (bypasses CDN). Use direct Garage address.
# On homelab deploy: http://127.0.0.1:3900 (same host as Garage)
# On local dev with SSH tunnel: http://127.0.0.1:13900
S3_INTERNAL_ENDPOINT=http://127.0.0.1:3900

MEDIA_UPLOAD_URL_TTL_SECONDS=900
MEDIA_DOWNLOAD_URL_TTL_SECONDS=604800
MEDIA_MAX_FILE_SIZE_BYTES=10485760
MEDIA_ALLOWED_CONTENT_TYPE_PREFIXES=image/

# Public base URL for direct S3 access (bucket must have public-read policy)
S3_PUBLIC_BASE_URL=https://s3.philand.io.vn
